# ─── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-vercel-app.vercel.app

# ─── MongoDB ──────────────────────────────────────────────
# If password contains @, encode it as %40
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/mnit-tshirt?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=<generate-a-64-char-random-string>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<generate-a-different-64-char-random-string>
JWT_REFRESH_EXPIRES_IN=30d

# ─── Super Admin Seed (one-time use) ─────────────────────
SUPER_ADMIN_EMAIL=superadmin@mnit.ac.in
SUPER_ADMIN_PASSWORD=SuperSecure@MNIT2024
SUPER_ADMIN_NAME=Super Admin MNIT

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
